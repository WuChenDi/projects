{
  "name": "@cdlab996/cipher",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Stream encryption/decryption library supporting password-based (Argon2id) and public-key (ECIES) modes with XChaCha20-Poly1305.",
  "author": "wudi <wuchendi96@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/WuChenDi",
  "repository": {
    "type": "git",
    "url": "https://github.com/WuChenDi/projects.git",
    "directory": "packages/cipher"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest --run",
    "test:watch": "vitest",
    "typecheck": "tsc --project ./tsconfig.json --noEmit",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@cdlab996/uncrypto": "workspace:*",
    "@noble/ciphers": "^2.1.1",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@scure/base": "^2.0.0",
    "eciesjs": "^0.4.18"
  },
  "devDependencies": {
    "@cdlab996/tsconfig": "workspace:*",
    "@types/node": "catalog:dev",
    "happy-dom": "^20.8.9",
    "jsdom": "catalog:dev",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:dev"
  }
}
