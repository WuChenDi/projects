{
  "name": "@cdlab996/projects-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "description": "A monorepo for my projects.",
  "author": "wudi <wuchendi96@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/WuChenDi",
  "repository": {
    "type": "git",
    "url": "https://github.com/WuChenDi/projects.git"
  },
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:baccarat": "turbo dev --filter=./apps/baccarat",
    "dev:bycut": "turbo dev --filter=./apps/bycut",
    "dev:byplay": "turbo dev --filter=./apps/byplay",
    "dev:byplay-log": "turbo dev --filter=./apps/byplay-log",
    "dev:bytts": "turbo dev --filter=./apps/bytts",
    "dev:clearify": "turbo dev --filter=./apps/clearify",
    "dev:dropply": "turbo dev --filter=./apps/dropply-*",
    "dev:flox": "turbo dev --filter=./apps/flox",
    "dev:live-user": "turbo dev --filter=./apps/live-user",
    "dev:repo-changelog": "turbo dev --filter=./apps/repo-changelog",
    "dev:securec": "turbo dev --filter=./apps/SecureC",
    "dev:shortener": "turbo dev --filter=./apps/shortener",
    "dev:text2img": "turbo dev --filter=./apps/text2img",
    "dev:values": "turbo dev --filter=./apps/values",
    "dev:vidl": "turbo dev --filter=./apps/vidl",
    "preview:text2img": "turbo preview --filter=./apps/text2img",
    "deploy:baccarat": "turbo deploy --filter=./apps/baccarat",
    "deploy:dropply-api": "turbo deploy --filter=./apps/dropply-api",
    "deploy:live-user": "turbo deploy --filter=./apps/live-user",
    "deploy:shortener": "turbo deploy --filter=./apps/shortener",
    "deploy:text2img": "turbo deploy --filter=./apps/text2img",
    "clean": "bash ./scripts/clean.sh",
    "lint": "turbo lint",
    "lint:biome": "biome check .",
    "format": "biome format . --write",
    "prepare": "turbo run build --filter=./packages/*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@cdlab996/tsconfig": "workspace:*",
    "@nsio/nsl": "^0.1.5",
    "@types/node": "catalog:dev",
    "turbo": "^2.9.8",
    "typescript": "catalog:dev"
  }
}
