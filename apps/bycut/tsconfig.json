{
  "extends": "@cdlab/tsconfig/nextjs.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@cdlab/ui/*": ["../../packages/ui/src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "apps/web/.next/types/**/*.ts",
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "src/types/**/*.d.ts",
    "../../use-frame-cache.ts",
    "src/stores/timeline-store.ts",
    ".next/dev/types/**/*.ts",
    "next.config.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
