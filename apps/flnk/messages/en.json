      "items": {
        "create": {
          "title": "Create a short link",
          "desc": "Paste a long URL and get a clean slug — or let AI suggest one for you."
        },
        "route": {
          "title": "Add routing & rules",
          "desc": "Route by country or device, gate behind a password, and set an expiry."
        },
        "track": {
          "title": "Share & track",
          "desc": "Every click streams into Analytics Engine — geo, device and referrer, live."
        }
      },
      "eyebrow": "Workflow"
    },
    "faq": {
      "title": "Frequently asked",
      "subtitle": "Everything you might wonder before you create a link.",
      "items": {
        "cost": {
          "q": "Is it free?",
          "a": "Yes. Flnk is open source (MIT) and runs on your own Cloudflare account — you only pay Cloudflare's usage, if any."
        },
        "data": {
          "q": "Where is my data stored?",
          "a": "In your own Cloudflare D1 / Turso database and Analytics Engine. Nothing is sent to a third party."
        },
        "geo": {
          "q": "How does geo / device routing work?",
          "a": "Each link can map countries or Apple / Android devices to different destinations, resolved at the edge with no cold start."
        },
        "privacy": {
          "q": "Do you track visitors?",
          "a": "Only aggregated click analytics in your own account — no third-party trackers and no visitor cookies."
        },
        "auth": {
          "q": "Who can access the dashboard?",
          "a": "The dashboard is gated by Google / GitHub sign-in, so only the accounts you allow can manage links."
        },
        "deploy": {
          "q": "How do I deploy it?",
          "a": "Deploy to your own Cloudflare account with a single command — it builds with OpenNext and ships to Workers, with no separate origin server to run."
        },
        "domain": {
          "q": "Can I use my own domain?",
          "a": "Yes. Point a custom domain at the Worker in Cloudflare and your short links live on your own brand."
        },
        "expiry": {
          "q": "Can links expire or be password-protected?",
          "a": "Yes. Each link can have an expiry date, an access password, and an interstitial warning for unsafe destinations."
        },
        "ai": {
          "q": "How are the AI slugs generated?",
          "a": "Workers AI reads the destination and suggests a short, readable slug — it falls back to a Base62 hash if AI is disabled or unavailable."
        },
        "import": {
          "q": "Can I import or export my links?",
          "a": "Yes. Bulk-migrate links via JSON import, and export your click analytics as CSV straight from the dashboard."
        }
      },
      "eyebrow": "FAQ"
    },
