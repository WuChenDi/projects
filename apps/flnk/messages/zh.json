    "faq": {
      "title": "常见问题",
      "subtitle": "创建链接前你可能想了解的一切。",
      "items": {
        "cost": {
          "q": "是免费的吗?",
          "a": "是。Flnk 开源(MIT),运行在你自己的 Cloudflare 账号上,只需承担 Cloudflare 的用量费用(若有)。"
        },
        "data": {
          "q": "我的数据存在哪里?",
          "a": "存在你自己的 Cloudflare D1 / Turso 数据库与 Analytics Engine 中,不会发送给任何第三方。"
        },
        "geo": {
          "q": "地域 / 设备路由如何工作?",
          "a": "每条链接都能把国家或 Apple / Android 设备映射到不同目标,在边缘解析,无冷启动。"
        },
        "privacy": {
          "q": "你们会追踪访客吗?",
          "a": "只在你自己的账号里做聚合点击分析 —— 没有第三方追踪,也不给访客种 Cookie。"
        },
        "auth": {
          "q": "谁能访问控制台?",
          "a": "控制台通过 Google / GitHub 登录把关,只有你允许的账号才能管理链接。"
        },
        "deploy": {
          "q": "如何部署?",
          "a": "用一条命令部署到你自己的 Cloudflare 账号 —— 基于 OpenNext 构建并发布到 Workers,无需单独的源站。"
        },
        "domain": {
          "q": "可以用我自己的域名吗?",
          "a": "可以。在 Cloudflare 把自定义域名指向该 Worker,短链就跑在你自己的品牌域名上。"
        },
        "expiry": {
          "q": "链接可以设置过期或密码吗?",
          "a": "可以。每条链接都能设置过期时间、访问密码,以及对不安全目标的风险提示页。"
        },
        "ai": {
          "q": "AI 短码是怎么生成的?",
          "a": "Workers AI 会读取目标地址并给出简短可读的短码 —— 若 AI 关闭或不可用,则回退到 Base62 哈希。"
        },
        "import": {
          "q": "可以导入 / 导出链接吗?",
          "a": "可以。通过 JSON 批量迁移链接,并在控制台把点击分析导出为 CSV。"
        }
      },
      "eyebrow": "常见问题"
    },
