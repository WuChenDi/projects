# Shared token that gates the dashboard + every /api/* route (required).
SITE_TOKEN=SinkSecretToken

# Database Type — 'libsql' for LibSQL/Turso or 'd1' for Cloudflare D1.
DB_TYPE=libsql

# LibSQL Configuration. Default is a local SQLite file.
LIBSQL_URL=file:./src/database/data.db
LIBSQL_AUTH_TOKEN=your-libsql-auth-token

# Cloudflare Configuration (drizzle-kit d1-http driver).
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_DATABASE_ID=

# Redirect engine knobs (optional — defaults shown).
REDIRECT_STATUS_CODE=308
LINK_CACHE_TTL=60
REDIRECT_WITH_QUERY=false
HOME_URL=
NOT_FOUND_REDIRECT=
CASE_SENSITIVE=false
SLUG_DEFAULT_LENGTH=6
LIST_QUERY_LIMIT=500

# Analytics Engine knobs.
DATASET=sink_analytics
DISABLE_BOT_ACCESS_LOG=false

# AI slug generation knobs.
AI_MODEL=@cf/meta/llama-3.1-8b-instruct
AI_PROMPT=
