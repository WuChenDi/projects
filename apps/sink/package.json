{
  "name": "@cdlab996/sink",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Privacy-first link shortener with geo / device routing and analytics — Next.js + Drizzle on Cloudflare Workers.",
  "license": "MIT",
  "scripts": {
    "dev": "nsl run --name \"sink\" -f next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "cf:localdb": "wrangler d1 migrations apply sink",
    "cf:remotedb": "wrangler d1 migrations apply sink --remote",
    "db:gen": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio --port 3021 --host 0.0.0.0"
  },
  "dependencies": {
    "@cdlab996/genid": "catalog:prod",
    "@cdlab996/ui": "workspace:*",
    "@cdlab996/utils": "workspace:*",
    "@libsql/client": "catalog:prod",
    "@tanstack/react-form": "catalog:prod",
    "@tanstack/react-query": "catalog:prod",
    "better-auth": "catalog:prod",
    "cobe": "^2.0.1",
    "drizzle-orm": "catalog:prod",
    "lucide-react": "catalog:prod",
    "next": "catalog:prod",
    "next-intl": "catalog:prod",
    "next-themes": "catalog:prod",
    "react": "catalog:prod",
    "react-dom": "catalog:prod",
    "react-simple-maps": "^3.0.0",
    "recharts": "catalog:prod",
    "sonner": "catalog:prod",
    "ua-parser-js": "^2.0.9",
    "zod": "catalog:prod",
    "zustand": "catalog:prod"
  },
  "devDependencies": {
    "@cdlab996/tsconfig": "workspace:*",
    "@cloudflare/workers-types": "catalog:dev",
    "@opennextjs/cloudflare": "catalog:dev",
    "@types/node": "catalog:dev",
    "@types/react": "catalog:dev",
    "@types/react-dom": "catalog:dev",
    "@types/react-simple-maps": "^3.0.6",
    "drizzle-kit": "catalog:dev",
    "typescript": "catalog:dev",
    "world-atlas": "^2.0.2",
    "wrangler": "catalog:dev"
  }
}
