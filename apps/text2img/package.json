{
  "name": "@cdlab996/text2img",
  "type": "module",
  "version": "1.1.0",
  "private": true,
  "description": "Free online AI text-to-image tool powered by Cloudflare Workers AI. Supports FLUX.1, Stable Diffusion XL and more. No registration required.",
  "author": "wudi <wuchendi96@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/WuChenDi",
  "repository": {
    "type": "git",
    "url": "https://github.com/WuChenDi/projects.git",
    "directory": "apps/text2img"
  },
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3012",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts"
  },
  "dependencies": {
    "@cdlab996/genid": "catalog:prod",
    "@cdlab996/ui": "workspace:*",
    "@cdlab996/utils": "workspace:*",
    "@tanstack/react-query": "catalog:prod",
    "class-variance-authority": "catalog:prod",
    "clsx": "catalog:prod",
    "date-fns": "catalog:prod",
    "lucide-react": "catalog:prod",
    "next": "catalog:prod",
    "next-intl": "catalog:prod",
    "next-themes": "catalog:prod",
    "react": "catalog:prod",
    "react-dom": "catalog:prod",
    "sonner": "catalog:prod"
  },
  "devDependencies": {
    "@cdlab996/tsconfig": "workspace:*",
    "@opennextjs/cloudflare": "^1.18.0",
    "@types/node": "catalog:dev",
    "@types/react": "catalog:dev",
    "@types/react-dom": "catalog:dev",
    "typescript": "catalog:dev",
    "wrangler": "catalog:dev"
  }
}
