# Site Branding
NEXT_PUBLIC_SITE_NAME=Flox
NEXT_PUBLIC_SITE_TITLE=Flox - 视频聚合平台
NEXT_PUBLIC_SITE_DESCRIPTION=视频聚合平台

# Access Control
# Global password protection. Leave empty to disable.
ACCESS_PASSWORD=
# Whether to persist the unlocked state to localStorage (default: true).
# Set to "false" to only persist in sessionStorage (cleared on tab close).
PERSIST_PASSWORD=true

# Source Subscriptions
# Comma-separated list of JSON URLs to auto-load video sources from.
NEXT_PUBLIC_SUBSCRIPTION_SOURCES=

# Ad Filtering
# Comma-separated list of ad filter keywords.
AD_KEYWORDS=
# Absolute or CWD-relative path to a file containing ad filter keywords (one per line or comma-separated).
AD_KEYWORDS_FILE=
