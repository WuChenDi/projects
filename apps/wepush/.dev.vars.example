# Local dev secrets for `wrangler dev` / OpenNext local bindings.
# Copy to `.dev.vars` (gitignored) and fill in real values.
# In production, set each of these via `wrangler secret put <NAME>`.

BETTER_AUTH_SECRET="your-better-auth-secret"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"
# Only needed when DB_TYPE=libsql. In production LIBSQL_AUTH_TOKEN is a Worker
# secret synced by .github/workflows/deploy-wepush.yml (GitHub secret
# WEPUSH_LIBSQL_AUTH_TOKEN).
LIBSQL_URL="your-libsql-url"
LIBSQL_AUTH_TOKEN="your-libsql-auth-token"

# The async push queue (PUSH_QUEUE) is config-only — its binding lives in
# wrangler.jsonc, so there is NO secret var to set here. Create the queues once
# before deploying: `wrangler queues create wepush-push` and
# `wrangler queues create wepush-push-dlq`.
