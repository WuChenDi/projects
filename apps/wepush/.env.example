# Access password for the password gate (required).
ACCESS_PASSWORD=

# DB driver — libsql (file/turso) or d1 (Cloudflare D1 binding)
DB_TYPE=libsql
LIBSQL_URL=file:./src/database/data.db
LIBSQL_AUTH_TOKEN=

# Only used by drizzle-kit when DB_TYPE=d1
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_DATABASE_ID=
CLOUDFLARE_API_TOKEN=
